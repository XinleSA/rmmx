# =============================================================================
#
#  INSTRUCTIONS:
#    1. Copy this file to .env:   cp .env.example .env
#    2. Fill in all values below — DO NOT leave defaults in production
#    3. NEVER commit .env to git — it is already listed in .gitignore
#
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=xinle_db
POSTGRES_USER=your_pg_user
POSTGRES_PASSWORD=your_strong_pg_password

# --- MySQL ---
MYSQL_ROOT_PASSWORD=your_strong_mysql_root_password
MYSQL_PASSWORD=your_strong_mysql_password

# --- pgAdmin ---
PGADMIN_PASSWORD=your_strong_pgadmin_password

# --- n8n Database (must match a database created in postgres init) ---
N8N_DB=n8n

# --- Forgejo Database (must match a database created in postgres init) ---
FORGEJO_DB=forgejo
